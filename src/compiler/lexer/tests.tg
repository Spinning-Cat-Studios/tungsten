// src/compiler/lexer/tests.tg
// Tests for the Tungsten lexer.

use lexer::token::{
    TokenKind, Token, token_kind,
    TokIntLit, TokStringLit, TokCharLit, TokIdent, TokUnderscore,
    TokFn, TokLet, TokIf, TokElse, TokMatch, TokReturn,
    TokType, TokStruct, TokEnum, TokTrue, TokFalse,
    TokTheorem, TokLemma, TokAxiom, TokBy, TokHave, TokShow,
    TokAssume, TokForall, TokExists, TokProp, TokSorry, TokRefl,
    TokBool, TokNat, TokUnit, TokVoid, TokExtern, TokRef, TokMod,
    TokPub, TokUse, TokAs, TokCrate, TokReserved,
    TokLParen, TokRParen, TokLBrace, TokRBrace, TokLBracket, TokRBracket,
    TokLAngle, TokRAngle, TokComma, TokSemi, TokColon, TokColonColon,
    TokDot, TokDotDot, TokDotDotDot, TokArrow, TokFatArrow, TokAt,
    TokHash, TokQuestion, TokEq, TokEqEq, TokBangEq, TokLe, TokGe,
    TokPlus, TokPlusPlus, TokMinus, TokStar, TokSlash, TokPercent,
    TokAmp, TokAmpAmp, TokPipe, TokPipePipe, TokPipeRight, TokBang,
    TokCaret, TokTilde, TokWhitespace, TokLineComment, TokBlockComment,
    TokDocComment, TokEof, TokError
};
use lexer::scanner::{LexResult, tokenize,
    lex_result_tokens, lex_result_errors, tokenize_no_trivia};
use driver::ffi::{List, Nil, Cons};

fn count_tokens(toks: List<Token>) -> Nat {
    match toks {
        Nil() => 0,
        Cons(_, rest) => 1 + count_tokens(rest)
    }
}

fn first_token_kind(toks: List<Token>) -> TokenKind {
    match toks {
        Nil() => TokEof,
        Cons(t, _) => token_kind(t)
    }
}

fn test_empty_input() -> Bool {
    let result = tokenize("", "test.tg");
    count_tokens(lex_result_tokens(result)) == 1
}

fn test_identifier() -> Bool {
    let result = tokenize("foo", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIdent(name) => name == "foo",
        _ => false
    }
}

fn test_keyword_fn() -> Bool {
    let result = tokenize("fn", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokFn() => true,
        _ => false
    }
}

fn test_keyword_let() -> Bool {
    let result = tokenize("let", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokLet() => true,
        _ => false
    }
}

fn test_keyword_if() -> Bool {
    let result = tokenize("if", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIf() => true,
        _ => false
    }
}

fn test_keyword_mod() -> Bool {
    let result = tokenize("mod", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokMod() => true,
        _ => false
    }
}

fn test_number() -> Bool {
    let result = tokenize("42", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 42,
        _ => false
    }
}

fn test_string() -> Bool {
    let result = tokenize("\"hello\"", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokStringLit(s) => s == "hello",
        _ => false
    }
}

fn test_arrow() -> Bool {
    let result = tokenize("->", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokArrow() => true,
        _ => false
    }
}

fn test_fat_arrow() -> Bool {
    let result = tokenize("=>", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokFatArrow() => true,
        _ => false
    }
}

fn test_eq_eq() -> Bool {
    let result = tokenize("==", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokEqEq() => true,
        _ => false
    }
}

fn test_bang_eq() -> Bool {
    let result = tokenize("!=", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokBangEq() => true,
        _ => false
    }
}

fn test_line_comment() -> Bool {
    let result = tokenize("// comment\nx", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokLineComment(_) => true,
        TokDocComment(_) => true,
        _ => false
    }
}

fn test_function_signature() -> Bool {
    let result = tokenize("fn add(x: Nat) -> Nat", "test.tg");
    count_tokens(lex_result_tokens(result)) == 10
}

fn test_reserved_keyword() -> Bool {
    let result = tokenize("async", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokReserved(kw) => kw == "async",
        _ => false
    }
}

fn test_underscore() -> Bool {
    let result = tokenize("_", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokUnderscore() => true,
        _ => false
    }
}

fn test_underscore_ident() -> Bool {
    let result = tokenize("_foo", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIdent(name) => name == "_foo",
        _ => false
    }
}

// Self-lex test: tokenize code similar to the lexer's own source
fn test_self_lex() -> Bool {
    let code = "fn span_new(start: Nat, end: Nat, file: String) -> Span { { start: start, end: end, file: file } }";
    let result = tokenize(code, "self.tg");
    let tokens = lex_result_tokens(result);
    let errors = lex_result_errors(result);
    // Should have many tokens and no errors
    if has_errors(errors) { false }
    else { count_tokens(tokens) > 20 }
}

// ---------------------------------------------------------------------------
// HEX/OCTAL/BINARY NUMBER TESTS
// ---------------------------------------------------------------------------
fn test_hex_number() -> Bool {
    let result = tokenize("0xFF", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 255,
        _ => false
    }
}

fn test_hex_number_uppercase() -> Bool {
    let result = tokenize("0X2A", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 42,
        _ => false
    }
}

// Test large hex values (uses NatLit for efficient representation)
fn test_hex_number_mixed_case() -> Bool {
    let result = tokenize("0xDeadBeef", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 3735928559,  // 0xDeadBeef
        _ => false
    }
}

fn test_hex_with_underscores() -> Bool {
    let result = tokenize("0xFF_FF", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 65535,  // 0xFF_FF
        _ => false
    }
}

fn test_octal_number() -> Bool {
    let result = tokenize("0o77", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 63,
        _ => false
    }
}

fn test_octal_number_uppercase() -> Bool {
    let result = tokenize("0O52", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 42,
        _ => false
    }
}

fn test_binary_number() -> Bool {
    let result = tokenize("0b1010", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 10,
        _ => false
    }
}

fn test_binary_number_uppercase() -> Bool {
    let result = tokenize("0B11111111", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 255,
        _ => false
    }
}

fn test_binary_with_underscores() -> Bool {
    let result = tokenize("0b1111_0000", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 240,
        _ => false
    }
}

fn test_invalid_hex_empty() -> Bool {
    let result = tokenize("0x", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_invalid_octal_empty() -> Bool {
    let result = tokenize("0o", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_invalid_binary_empty() -> Bool {
    let result = tokenize("0b", "test.tg");
    has_errors(lex_result_errors(result))
}

// ---------------------------------------------------------------------------
// ERROR CONDITION TESTS
// ---------------------------------------------------------------------------
fn test_unterminated_string() -> Bool {
    let result = tokenize("\"hello", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_unterminated_char() -> Bool {
    let result = tokenize("'x", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_nested_block_comment() -> Bool {
    let result = tokenize("/* outer /* inner */ still outer */", "test.tg");
    let errors = lex_result_errors(result);
    !has_errors(errors)
}

fn test_unterminated_nested_block_comment() -> Bool {
    let result = tokenize("/* outer /* inner */", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_reserved_keyword_error() -> Bool {
    let result = tokenize("async", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_reserved_keyword_await() -> Bool {
    let result = tokenize("await", "test.tg");
    has_errors(lex_result_errors(result))
}

fn test_reserved_keyword_pub() -> Bool {
    let result = tokenize("pub", "test.tg");
    has_errors(lex_result_errors(result))
}

// ---------------------------------------------------------------------------
// EDGE CASE TESTS
// ---------------------------------------------------------------------------
fn test_zero() -> Bool {
    let result = tokenize("0", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 0,
        _ => false
    }
}

fn test_leading_zeros() -> Bool {
    let result = tokenize("007", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokIntLit(n) => n == 7,
        _ => false
    }
}

fn test_string_with_escape() -> Bool {
    let result = tokenize("\"hello\\nworld\"", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokStringLit(s) => s == "hello\\nworld",
        _ => false
    }
}

fn test_char_backslash_n() -> Bool {
    let result = tokenize("'\\n'", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokCharLit(_) => true,
        _ => false
    }
}

fn test_doc_comment() -> Bool {
    let result = tokenize("/// doc comment", "test.tg");
    match first_token_kind(lex_result_tokens(result)) {
        TokDocComment(_) => true,
        _ => false
    }
}

fn run_tests() -> Nat {
    let passed = 0;
    // Original tests
    let passed = if test_empty_input() { passed + 1 } else { passed };
    let passed = if test_identifier() { passed + 1 } else { passed };
    let passed = if test_keyword_fn() { passed + 1 } else { passed };
    let passed = if test_keyword_let() { passed + 1 } else { passed };
    let passed = if test_keyword_if() { passed + 1 } else { passed };
    let passed = if test_keyword_mod() { passed + 1 } else { passed };
    let passed = if test_number() { passed + 1 } else { passed };
    let passed = if test_string() { passed + 1 } else { passed };
    let passed = if test_arrow() { passed + 1 } else { passed };
    let passed = if test_fat_arrow() { passed + 1 } else { passed };
    let passed = if test_eq_eq() { passed + 1 } else { passed };
    let passed = if test_bang_eq() { passed + 1 } else { passed };
    let passed = if test_line_comment() { passed + 1 } else { passed };
    let passed = if test_function_signature() { passed + 1 } else { passed };
    let passed = if test_reserved_keyword() { passed + 1 } else { passed };
    let passed = if test_underscore() { passed + 1 } else { passed };
    let passed = if test_underscore_ident() { passed + 1 } else { passed };
    let passed = if test_self_lex() { passed + 1 } else { passed };
    // Hex/octal/binary number tests
    let passed = if test_hex_number() { passed + 1 } else { passed };
    let passed = if test_hex_number_uppercase() { passed + 1 } else { passed };
    let passed = if test_hex_number_mixed_case() { passed + 1 } else { passed };
    let passed = if test_hex_with_underscores() { passed + 1 } else { passed };
    let passed = if test_octal_number() { passed + 1 } else { passed };
    let passed = if test_octal_number_uppercase() { passed + 1 } else { passed };
    let passed = if test_binary_number() { passed + 1 } else { passed };
    let passed = if test_binary_number_uppercase() { passed + 1 } else { passed };
    let passed = if test_binary_with_underscores() { passed + 1 } else { passed };
    let passed = if test_invalid_hex_empty() { passed + 1 } else { passed };
    let passed = if test_invalid_octal_empty() { passed + 1 } else { passed };
    let passed = if test_invalid_binary_empty() { passed + 1 } else { passed };
    // Error condition tests
    let passed = if test_unterminated_string() { passed + 1 } else { passed };
    let passed = if test_unterminated_char() { passed + 1 } else { passed };
    let passed = if test_nested_block_comment() { passed + 1 } else { passed };
    let passed = if test_unterminated_nested_block_comment() { passed + 1 } else { passed };
    let passed = if test_reserved_keyword_error() { passed + 1 } else { passed };
    let passed = if test_reserved_keyword_await() { passed + 1 } else { passed };
    let passed = if test_reserved_keyword_pub() { passed + 1 } else { passed };
    // Edge case tests
    let passed = if test_zero() { passed + 1 } else { passed };
    let passed = if test_leading_zeros() { passed + 1 } else { passed };
    let passed = if test_string_with_escape() { passed + 1 } else { passed };
    let passed = if test_char_backslash_n() { passed + 1 } else { passed };
    let passed = if test_doc_comment() { passed + 1 } else { passed };
    passed
}
