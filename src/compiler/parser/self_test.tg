// ============================================================================
// Test runner
// ============================================================================

fn count_passed(results: TestResultList) -> Nat {
    match results {
        TestResultNil() => 0,
        TestResultCons(r, rest) => {
            let n = count_passed(rest);
            if r.passed { n + 1 } else { n }
        }
    }
}

fn count_failed(results: TestResultList) -> Nat {
    match results {
        TestResultNil() => 0,
        TestResultCons(r, rest) => {
            let n = count_failed(rest);
            if r.passed { n } else { n + 1 }
        }
    }
}

fn count_total(results: TestResultList) -> Nat {
    match results {
        TestResultNil() => 0,
        TestResultCons(_, rest) => 1 + count_total(rest),
    }
}

