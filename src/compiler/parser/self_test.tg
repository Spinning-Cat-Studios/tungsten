// ============================================================================
// Result tracking
// ============================================================================

type TestResult = {
    name: String,
    passed: Bool,
    message: String,
}

type TestResultList =
    | TestResultNil
    | TestResultCons(TestResult, TestResultList)

fn test_result_passed(name: String) -> TestResult {
    { name: name, passed: true, message: "" }
}

fn test_result_failed(name: String, message: String) -> TestResult {
    { name: name, passed: false, message: message }
}

