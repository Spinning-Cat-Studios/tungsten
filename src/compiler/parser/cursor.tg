// src/compiler/parser/cursor.tg
// Token cursor for the Tungsten parser.
//
// The Cursor type provides an immutable view over a List<Token>,
// supporting O(1) peek and advance operations. Unlike the Rust parser
// which uses mutable indexing, we thread the cursor through parse
// functions functionally.
//
// Note: Uses Token, TokenKind, List<Token>, Span from lexer (via module hierarchy)
// Note: Uses ParseError from sibling error module (via module hierarchy)

// Import types from lexer module
use lexer::token::{
    Token, TokenKind, token_kind, token_span,
    TokIdent, TokFn, TokLet, TokIf, TokElse, TokMatch, TokReturn,
    TokType, TokStruct, TokEnum, TokTrue, TokFalse,
    TokTheorem, TokLemma, TokAxiom, TokBy, TokHave, TokShow,
    TokAssume, TokForall, TokExists, TokProp, TokSorry, TokRefl,
    TokBool, TokNat, TokUnit, TokVoid, TokExtern, TokRef, TokMod,
    TokPub, TokUse, TokAs, TokCrate, TokUnderscore,
    TokLParen, TokRParen, TokLBrace, TokRBrace, TokLBracket, TokRBracket,
    TokLAngle, TokRAngle, TokComma, TokSemi, TokColon, TokColonColon,
    TokDot, TokDotDot, TokDotDotDot, TokArrow, TokFatArrow, TokAt,
    TokHash, TokQuestion, TokEq, TokBangEq, TokLe, TokGe,
    TokPlus, TokMinus, TokStar, TokSlash, TokPercent,
    TokAmp, TokAmpAmp, TokPipe, TokPipePipe, TokPipeRight, TokBang,
    TokCaret, TokTilde, TokEof, TokError, TokIntLit, TokStringLit
};
use driver::ffi::{List, Nil, Cons};
use lexer::span::{Span, span_empty};

// Import ParseError and constructors from sibling error module  
use parser::error::{ParseError, parse_error_expected, parse_error_eof};

// Import Option from sibling module
use parser::option::{Option, None, Some};

// ---------------------------------------------------------------------------
// CURSOR TYPE
// ---------------------------------------------------------------------------

/// Cursor is an immutable position in a token stream.
/// Each parse function takes a Cursor and returns a new Cursor.
pub type Cursor = {
    remaining: List<Token>,   // Tokens yet to be consumed
    position: Nat,            // Token index (for debugging/errors)
    filename: String          // Source filename (for error spans)
}

// ---------------------------------------------------------------------------
// MAYBE TYPES THAT DEPEND ON CURSOR (defined after Cursor)
// ---------------------------------------------------------------------------

/// Optional Cursor (for eat operations)
pub type MaybeCursor =
    | NoCursor
    | SomeCursor(Cursor)

/// Result of consuming an identifier: the name and new cursor.
pub type EatIdentResult =
    | NoIdentResult
    | SomeIdentResult(String, Cursor)

/// Result of consuming an integer literal: the value and new cursor.
pub type EatIntResult =
    | NoIntResult
    | SomeIntResult(Nat, Cursor)

/// Result of consuming a string literal: the value and new cursor.
pub type EatStringResult =
    | NoStringResult
    | SomeStringResult(String, Cursor)

// ---------------------------------------------------------------------------
// CURSOR ACCESSORS
// ---------------------------------------------------------------------------

/// Create a new cursor from a token list.
pub fn cursor_new(tokens: List<Token>, filename: String) -> Cursor {
    { remaining: tokens, position: 0, filename: filename }
}

/// Get the remaining token list.
pub fn cursor_remaining(c: Cursor) -> List<Token> {
    c.remaining
}

/// Get the current position (token index).
pub fn cursor_position(c: Cursor) -> Nat {
    c.position
}

/// Get the filename.
pub fn cursor_filename(c: Cursor) -> String {
    c.filename
}

// ---------------------------------------------------------------------------
// PEEK OPERATIONS (non-consuming)
// ---------------------------------------------------------------------------

/// Peek at the current token without consuming it.
/// Returns None if at end of stream.
pub fn cursor_peek(c: Cursor) -> Option<Token> {
    match c.remaining {
        Nil() => None,
        Cons(tok, _) => Some(tok)
    }
}

/// Peek at the current token's kind.
/// Returns None if at end of stream.
pub fn cursor_peek_kind(c: Cursor) -> Option<TokenKind> {
    match cursor_peek(c) {
        None() => None,
        Some(tok) => Some(tok.kind)
    }
}

/// Peek at the current token's span.
/// Returns an empty span at position 0 if at end of stream.
pub fn cursor_peek_span(c: Cursor) -> Span {
    match cursor_peek(c) {
        None() => span_empty(c.position, c.filename),
        Some(tok) => tok.span
    }
}

/// Check if we're at the end of the token stream.
pub fn cursor_is_eof(c: Cursor) -> Bool {
    match c.remaining {
        Nil() => true,
        Cons(tok, _) => match tok.kind {
            TokEof() => true,
            _ => false
        }
    }
}

// ---------------------------------------------------------------------------
// CHECK OPERATIONS (non-consuming predicates)
// ---------------------------------------------------------------------------

/// Check if current token has the specified kind (without consuming).
pub fn cursor_check(c: Cursor, kind: TokenKind) -> Bool {
    match cursor_peek_kind(c) {
        None() => false,
        Some(k) => token_kind_eq(k, kind)
    }
}

/// Check if current token is an identifier (without consuming).
pub fn cursor_check_ident(c: Cursor) -> Bool {
    match cursor_peek_kind(c) {
        None() => false,
        Some(k) => match k {
            TokIdent(_) => true,
            _ => false
        }
    }
}

/// Check if current token is an integer literal (without consuming).
pub fn cursor_check_int(c: Cursor) -> Bool {
    match cursor_peek_kind(c) {
        None() => false,
        Some(k) => match k {
            TokIntLit(_) => true,
            _ => false
        }
    }
}

/// Check if current token is a string literal (without consuming).
pub fn cursor_check_string(c: Cursor) -> Bool {
    match cursor_peek_kind(c) {
        None() => false,
        Some(k) => match k {
            TokStringLit(_) => true,
            _ => false
        }
    }
}

/// Check if the token one position ahead matches the given kind.
/// Used for disambiguation (e.g., `:` vs `::`).
pub fn cursor_check_ahead(c: Cursor, kind: TokenKind) -> Bool {
    let c2 = cursor_advance(c);
    cursor_check(c2, kind)
}

/// Check if the token N positions ahead matches the given kind.
/// N=0 checks current, N=1 checks one ahead, etc.
pub fn cursor_check_ahead_n(c: Cursor, n: Nat, kind: TokenKind) -> Bool {
    if n == 0 {
        cursor_check(c, kind)
    } else {
        cursor_check_ahead_n(cursor_advance(c), n - 1, kind)
    }
}

// ---------------------------------------------------------------------------
// ADVANCE OPERATIONS (consuming)
// ---------------------------------------------------------------------------

/// Advance the cursor by one token, returning the new cursor.
/// If already at end, returns the same cursor.
pub fn cursor_advance(c: Cursor) -> Cursor {
    match c.remaining {
        Nil() => c,
        Cons(_, rest) => {
            let result: Cursor = { remaining: rest, position: c.position + 1, filename: c.filename };
            result
        }
    }
}

/// Consume the current token if it matches the expected kind.
/// Returns SomeCursor(new_cursor) on match, NoCursor otherwise.
pub fn cursor_eat(c: Cursor, kind: TokenKind) -> MaybeCursor {
    if cursor_check(c, kind) {
        SomeCursor(cursor_advance(c))
    } else {
        NoCursor
    }
}

/// Consume an identifier and return its name.
/// Returns SomeIdentResult(name, new_cursor) on match, NoIdentResult otherwise.
pub fn cursor_eat_ident(c: Cursor) -> EatIdentResult {
    match c.remaining {
        Nil() => NoIdentResult,
        Cons(tok, _) => match tok.kind {
            TokIdent(name) => SomeIdentResult(name, cursor_advance(c)),
            _ => NoIdentResult
        }
    }
}

/// Consume an integer literal and return its value.
/// Returns SomeIntResult(value, new_cursor) on match, NoIntResult otherwise.
pub fn cursor_eat_int(c: Cursor) -> EatIntResult {
    match c.remaining {
        Nil() => NoIntResult,
        Cons(tok, _) => match tok.kind {
            TokIntLit(n) => SomeIntResult(n, cursor_advance(c)),
            _ => NoIntResult
        }
    }
}

/// Consume a string literal and return its value.
/// Returns SomeStringResult(value, new_cursor) on match, NoStringResult otherwise.
pub fn cursor_eat_string(c: Cursor) -> EatStringResult {
    match c.remaining {
        Nil() => NoStringResult,
        Cons(tok, _) => match tok.kind {
            TokStringLit(s) => SomeStringResult(s, cursor_advance(c)),
            _ => NoStringResult
        }
    }
}

// ---------------------------------------------------------------------------
// PARSE RESULT TYPES (concrete, for each return type)
// ---------------------------------------------------------------------------

/// Result of parsing a Token (from cursor_expect)
pub type ParseResultToken =
    | ParseOkToken(Token, Cursor)
    | ParseErrToken(ParseError)

/// Result of parsing a String (from cursor_expect_ident, cursor_expect_string)
pub type ParseResultString =
    | ParseOkString(String, Cursor)
    | ParseErrString(ParseError)

/// Result of parsing a Nat (from cursor_expect_int)
pub type ParseResultNat =
    | ParseOkNat(Nat, Cursor)
    | ParseErrNat(ParseError)

// Note: Add more concrete ParseResult types as needed for other parse functions.
// Generic ParseResult<T> has type inference issues in Tungsten.

// ---------------------------------------------------------------------------
// EXPECT OPERATIONS (consuming with error on mismatch)
// ---------------------------------------------------------------------------

/// Expect and consume a specific token kind.
/// Returns ParseOkToken(token, new_cursor) on match, ParseErrToken on mismatch.
pub fn cursor_expect(c: Cursor, kind: TokenKind) -> ParseResultToken {
    match c.remaining {
        Nil() => ParseErrToken(parse_error_eof(token_kind_name(kind), span_empty(c.position, c.filename))),
        Cons(tok, _) => {
            if token_kind_eq(tok.kind, kind) {
                ParseOkToken(tok, cursor_advance(c))
            } else {
                ParseErrToken(parse_error_expected(
                    token_kind_name(kind),
                    token_kind_name(tok.kind),
                    tok.span
                ))
            }
        }
    }
}

/// Expect and consume an identifier.
/// Returns ParseOkString(name, new_cursor) on match, ParseErrString on mismatch.
pub fn cursor_expect_ident(c: Cursor) -> ParseResultString {
    match c.remaining {
        Nil() => ParseErrString(parse_error_eof("identifier", span_empty(c.position, c.filename))),
        Cons(tok, _) => match tok.kind {
            TokIdent(name) => ParseOkString(name, cursor_advance(c)),
            _ => ParseErrString(parse_error_expected("identifier", token_kind_name(tok.kind), tok.span))
        }
    }
}

/// Expect and consume an integer literal.
/// Returns ParseOkNat(value, new_cursor) on match, ParseErrNat on mismatch.
pub fn cursor_expect_int(c: Cursor) -> ParseResultNat {
    match c.remaining {
        Nil() => ParseErrNat(parse_error_eof("integer literal", span_empty(c.position, c.filename))),
        Cons(tok, _) => match tok.kind {
            TokIntLit(n) => ParseOkNat(n, cursor_advance(c)),
            _ => ParseErrNat(parse_error_expected("integer literal", token_kind_name(tok.kind), tok.span))
        }
    }
}

/// Expect and consume a string literal.
/// Returns ParseOkString(value, new_cursor) on match, ParseErrString on mismatch.
pub fn cursor_expect_string(c: Cursor) -> ParseResultString {
    match c.remaining {
        Nil() => ParseErrString(parse_error_eof("string literal", span_empty(c.position, c.filename))),
        Cons(tok, _) => match tok.kind {
            TokStringLit(s) => ParseOkString(s, cursor_advance(c)),
            _ => ParseErrString(parse_error_expected("string literal", token_kind_name(tok.kind), tok.span))
        }
    }
}

// ---------------------------------------------------------------------------
// TOKEN KIND HELPERS
// ---------------------------------------------------------------------------

/// Compare two token kinds for equality.
/// Note: For kinds with payloads (TokIdent, TokIntLit, etc.), only compares the variant.
pub fn token_kind_eq(a: TokenKind, b: TokenKind) -> Bool {
    match a {
        TokIntLit(_) => match b { TokIntLit(_) => true, _ => false },
        TokStringLit(_) => match b { TokStringLit(_) => true, _ => false },
        TokCharLit(_) => match b { TokCharLit(_) => true, _ => false },
        TokIdent(_) => match b { TokIdent(_) => true, _ => false },
        TokUnderscore() => match b { TokUnderscore() => true, _ => false },
        TokFn() => match b { TokFn() => true, _ => false },
        TokLet() => match b { TokLet() => true, _ => false },
        TokIf() => match b { TokIf() => true, _ => false },
        TokElse() => match b { TokElse() => true, _ => false },
        TokMatch() => match b { TokMatch() => true, _ => false },
        TokReturn() => match b { TokReturn() => true, _ => false },
        TokType() => match b { TokType() => true, _ => false },
        TokStruct() => match b { TokStruct() => true, _ => false },
        TokEnum() => match b { TokEnum() => true, _ => false },
        TokTrue() => match b { TokTrue() => true, _ => false },
        TokFalse() => match b { TokFalse() => true, _ => false },
        TokTheorem() => match b { TokTheorem() => true, _ => false },
        TokLemma() => match b { TokLemma() => true, _ => false },
        TokAxiom() => match b { TokAxiom() => true, _ => false },
        TokBy() => match b { TokBy() => true, _ => false },
        TokHave() => match b { TokHave() => true, _ => false },
        TokShow() => match b { TokShow() => true, _ => false },
        TokAssume() => match b { TokAssume() => true, _ => false },
        TokForall() => match b { TokForall() => true, _ => false },
        TokExists() => match b { TokExists() => true, _ => false },
        TokProp() => match b { TokProp() => true, _ => false },
        TokSorry() => match b { TokSorry() => true, _ => false },
        TokBool() => match b { TokBool() => true, _ => false },
        TokNat() => match b { TokNat() => true, _ => false },
        TokUnit() => match b { TokUnit() => true, _ => false },
        TokVoid() => match b { TokVoid() => true, _ => false },
        TokExtern() => match b { TokExtern() => true, _ => false },
        TokRef() => match b { TokRef() => true, _ => false },
        TokMod() => match b { TokMod() => true, _ => false },
        TokReserved(_) => match b { TokReserved(_) => true, _ => false },
        TokLParen() => match b { TokLParen() => true, _ => false },
        TokRParen() => match b { TokRParen() => true, _ => false },
        TokLBrace() => match b { TokLBrace() => true, _ => false },
        TokRBrace() => match b { TokRBrace() => true, _ => false },
        TokLBracket() => match b { TokLBracket() => true, _ => false },
        TokRBracket() => match b { TokRBracket() => true, _ => false },
        TokLAngle() => match b { TokLAngle() => true, _ => false },
        TokRAngle() => match b { TokRAngle() => true, _ => false },
        TokComma() => match b { TokComma() => true, _ => false },
        TokSemi() => match b { TokSemi() => true, _ => false },
        TokColon() => match b { TokColon() => true, _ => false },
        TokColonColon() => match b { TokColonColon() => true, _ => false },
        TokDot() => match b { TokDot() => true, _ => false },
        TokDotDot() => match b { TokDotDot() => true, _ => false },
        TokDotDotDot() => match b { TokDotDotDot() => true, _ => false },
        TokArrow() => match b { TokArrow() => true, _ => false },
        TokFatArrow() => match b { TokFatArrow() => true, _ => false },
        TokAt() => match b { TokAt() => true, _ => false },
        TokHash() => match b { TokHash() => true, _ => false },
        TokQuestion() => match b { TokQuestion() => true, _ => false },
        TokEq() => match b { TokEq() => true, _ => false },
        TokEqEq() => match b { TokEqEq() => true, _ => false },
        TokBangEq() => match b { TokBangEq() => true, _ => false },
        TokLe() => match b { TokLe() => true, _ => false },
        TokGe() => match b { TokGe() => true, _ => false },
        TokPlus() => match b { TokPlus() => true, _ => false },
        TokPlusPlus() => match b { TokPlusPlus() => true, _ => false },
        TokMinus() => match b { TokMinus() => true, _ => false },
        TokStar() => match b { TokStar() => true, _ => false },
        TokSlash() => match b { TokSlash() => true, _ => false },
        TokPercent() => match b { TokPercent() => true, _ => false },
        TokAmp() => match b { TokAmp() => true, _ => false },
        TokAmpAmp() => match b { TokAmpAmp() => true, _ => false },
        TokPipe() => match b { TokPipe() => true, _ => false },
        TokPipePipe() => match b { TokPipePipe() => true, _ => false },
        TokPipeRight() => match b { TokPipeRight() => true, _ => false },
        TokBang() => match b { TokBang() => true, _ => false },
        TokCaret() => match b { TokCaret() => true, _ => false },
        TokTilde() => match b { TokTilde() => true, _ => false },
        TokWhitespace() => match b { TokWhitespace() => true, _ => false },
        TokLineComment(_) => match b { TokLineComment(_) => true, _ => false },
        TokBlockComment(_) => match b { TokBlockComment(_) => true, _ => false },
        TokDocComment(_) => match b { TokDocComment(_) => true, _ => false },
        TokEof() => match b { TokEof() => true, _ => false },
        TokError(_) => match b { TokError(_) => true, _ => false },
        TokRefl() => match b { TokRefl() => true, _ => false },
        TokPub() => match b { TokPub() => true, _ => false },
        TokUse() => match b { TokUse() => true, _ => false },
        TokAs() => match b { TokAs() => true, _ => false },
        TokCrate() => match b { TokCrate() => true, _ => false }
    }
}

/// Get a human-readable name for a token kind.
pub fn token_kind_name(k: TokenKind) -> String {
    match k {
        TokIntLit(_) => "integer literal",
        TokStringLit(_) => "string literal",
        TokCharLit(_) => "character literal",
        TokIdent(_) => "identifier",
        TokUnderscore() => "'_'",
        TokFn() => "'fn'",
        TokLet() => "'let'",
        TokIf() => "'if'",
        TokElse() => "'else'",
        TokMatch() => "'match'",
        TokReturn() => "'return'",
        TokType() => "'type'",
        TokStruct() => "'struct'",
        TokEnum() => "'enum'",
        TokTrue() => "'true'",
        TokFalse() => "'false'",
        TokTheorem() => "'theorem'",
        TokLemma() => "'lemma'",
        TokAxiom() => "'axiom'",
        TokBy() => "'by'",
        TokHave() => "'have'",
        TokShow() => "'show'",
        TokAssume() => "'assume'",
        TokForall() => "'forall'",
        TokExists() => "'exists'",
        TokProp() => "'Prop'",
        TokSorry() => "'sorry'",
        TokBool() => "'Bool'",
        TokNat() => "'Nat'",
        TokUnit() => "'Unit'",
        TokVoid() => "'Void'",
        TokExtern() => "'extern'",
        TokRef() => "'Ref'",
        TokMod() => "'mod'",
        TokReserved(_) => "reserved keyword",
        TokLParen() => "'('",
        TokRParen() => "')'",
        TokLBrace() => "'{'",
        TokRBrace() => "'}'",
        TokLBracket() => "'['",
        TokRBracket() => "']'",
        TokLAngle() => "'<'",
        TokRAngle() => "'>'",
        TokComma() => "','",
        TokSemi() => "';'",
        TokColon() => "':'",
        TokColonColon() => "'::'",
        TokDot() => "'.'",
        TokDotDot() => "'..'",
        TokDotDotDot() => "'...'",
        TokArrow() => "'->'",
        TokFatArrow() => "'=>'",
        TokAt() => "'@'",
        TokHash() => "'#'",
        TokQuestion() => "'?'",
        TokEq() => "'='",
        TokEqEq() => "'=='",
        TokBangEq() => "'!='",
        TokLe() => "'<='",
        TokGe() => "'>='",
        TokPlus() => "'+'",
        TokPlusPlus() => "'++'",
        TokMinus() => "'-'",
        TokStar() => "'*'",
        TokSlash() => "'/'",
        TokPercent() => "'%'",
        TokAmp() => "'&'",
        TokAmpAmp() => "'&&'",
        TokPipe() => "'|'",
        TokPipePipe() => "'||'",
        TokPipeRight() => "'|>'",
        TokBang() => "'!'",
        TokCaret() => "'^'",
        TokTilde() => "'~'",
        TokWhitespace() => "whitespace",
        TokLineComment(_) => "line comment",
        TokBlockComment(_) => "block comment",
        TokDocComment(_) => "doc comment",
        TokEof() => "end of file",
        TokError(_) => "error token",
        TokRefl() => "'refl'",
        TokPub() => "'pub'",
        TokUse() => "'use'",
        TokAs() => "'as'",
        TokCrate() => "'crate'"
    }
}
