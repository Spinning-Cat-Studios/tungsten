// src/compiler/driver/pipeline/test/harness.tg
// Harness source-text generation for the test runner.

use driver::ffi::{
    List, Nil, Cons,
    string_len, string_char_at_internal, string_append_char
};
use driver::util::{nat_to_string};

// ===========================================================================
// SOURCE TEXT GENERATION
// ===========================================================================

/// Generate the harness source: user source (with main renamed) + harness main.
pub fn generate_harness_source(user_source: String, test_names: List<String>,
                           test_count: Nat) -> String {
    let modified_source = rename_user_main(user_source);
    let harness = generate_harness_main(test_names, test_count);
    modified_source ++ "\n\n" ++ harness_preamble() ++ "\n\n" ++ harness
}

/// Rename user's main() to avoid conflict with harness main.
fn rename_user_main(source: String) -> String {
    _test_replace_in_string(source, "pub fn main(", "pub fn _tungsten_user_main(")
}

/// Loop-invariant context for string replacement.
type ReplaceLoopCtx = {
    source: String,
    target: String,
    replacement: String
}

/// Simple string replacement (first occurrence only).
fn _test_replace_in_string(source: String, target: String, replacement: String) -> String {
    let s_len = string_len(source);
    let t_len = string_len(target);
    if t_len > s_len {
        source
    } else {
        let ctx: ReplaceLoopCtx = { source: source, target: target, replacement: replacement };
        _test_replace_in_string_loop(ctx, 0, s_len, t_len)
    }
}

fn _test_replace_in_string_loop(ctx: ReplaceLoopCtx,
                           i: Nat, s_len: Nat, t_len: Nat) -> String {
    if i > s_len - t_len {
        ctx.source
    } else {
        if _test_string_match_at_pos(ctx.source, ctx.target, i, t_len) {
            let prefix = _test_string_slice(ctx.source, 0, i);
            let suffix = _test_string_slice(ctx.source, i + t_len, s_len);
            prefix ++ ctx.replacement ++ suffix
        } else {
            _test_replace_in_string_loop(ctx, i + 1, s_len, t_len)
        }
    }
}

/// Check if source matches target at position i.
fn _test_string_match_at_pos(source: String, target: String, offset: Nat, t_len: Nat) -> Bool {
    _test_string_match_at_pos_loop(source, target, offset, 0, t_len)
}

fn _test_string_match_at_pos_loop(source: String, target: String,
                             offset: Nat, i: Nat, t_len: Nat) -> Bool {
    if i >= t_len {
        true
    } else {
        let cs = string_char_at_internal(source, offset + i);
        let ct = string_char_at_internal(target, i);
        if cs != ct {
            false
        } else {
            _test_string_match_at_pos_loop(source, target, offset, i + 1, t_len)
        }
    }
}

/// Extract a substring from start (inclusive) to end (exclusive).
fn _test_string_slice(s: String, start: Nat, end: Nat) -> String {
    _test_string_slice_acc(s, start, end, "")
}

fn _test_string_slice_acc(s: String, i: Nat, end: Nat, acc: String) -> String {
    if i >= end {
        acc
    } else {
        let c = string_char_at_internal(s, i);
        _test_string_slice_acc(s, i + 1, end, string_append_char(acc, c))
    }
}

// ===========================================================================
// HARNESS TEXT TEMPLATES
// ===========================================================================

/// FFI extern declarations needed by the harness.
fn harness_preamble() -> String {
    "// --- Test harness (generated by tungsten test) ---\n" ++
    "extern \"C\" fn tg_test_begin(name: Nat, len: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_test_check_failure() -> Nat\n" ++
    "extern \"C\" fn tg_println(s: Nat, len: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_print(s: Nat, len: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_exit(code: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_string_to_cstring(s: String) -> Nat\n" ++
    "extern \"C\" fn tg_free_string(s: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_string_len_internal(s: String) -> Nat\n" ++
    "extern \"C\" fn tg_assert_eq_nat(left: Nat, right: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_assert_eq_string(left: Nat, left_len: Nat, right: Nat, right_len: Nat) -> Unit\n" ++
    "extern \"C\" fn tg_assert_eq_bool(left: Nat, right: Nat) -> Unit\n" ++
    "\n" ++
    "fn _harness_println(s: String) -> Unit {\n" ++
    "    let c = tg_string_to_cstring(s);\n" ++
    "    let len = tg_string_len_internal(s);\n" ++
    "    tg_println(c, len);\n" ++
    "    tg_free_string(c)\n" ++
    "}\n" ++
    "\n" ++
    "fn _harness_test_begin(name: String) -> Unit {\n" ++
    "    let c = tg_string_to_cstring(name);\n" ++
    "    let len = tg_string_len_internal(name);\n" ++
    "    tg_test_begin(c, len);\n" ++
    "    tg_free_string(c)\n" ++
    "}\n" ++
    "\n" ++
    "fn assert_eq_nat(left: Nat, right: Nat) -> Unit {\n" ++
    "    tg_assert_eq_nat(left, right)\n" ++
    "}\n" ++
    "\n" ++
    "fn assert_eq_string(left: String, right: String) -> Unit {\n" ++
    "    let lc = tg_string_to_cstring(left);\n" ++
    "    let ll = tg_string_len_internal(left);\n" ++
    "    let rc = tg_string_to_cstring(right);\n" ++
    "    let rl = tg_string_len_internal(right);\n" ++
    "    tg_assert_eq_string(lc, ll, rc, rl);\n" ++
    "    tg_free_string(lc);\n" ++
    "    tg_free_string(rc)\n" ++
    "}\n" ++
    "\n" ++
    "fn assert_eq_bool(left: Bool, right: Bool) -> Unit {\n" ++
    "    let l = if left { 1 } else { 0 };\n" ++
    "    let r = if right { 1 } else { 0 };\n" ++
    "    tg_assert_eq_bool(l, r)\n" ++
    "}"
}

/// Generate the harness main function that calls all test_* functions.
fn generate_harness_main(test_names: List<String>, test_count: Nat) -> String {
    let header = "pub fn main() -> Nat {\n" ++
                 "    _harness_println(\"running " ++ nat_to_string(test_count) ++ " tests\");\n" ++
                 "    let failed = _harness_run_tests(0);\n" ++
                 "    if failed == 0 {\n" ++
                 "        _harness_println(\"test result: ok. " ++ nat_to_string(test_count) ++ " passed\");\n" ++
                 "        tg_exit(0)\n" ++
                 "    } else {\n" ++
                 "        _harness_println(\"test result: FAILED. \" ++ _harness_nat_to_string(failed) ++ \" failed\");\n" ++
                 "        tg_exit(1)\n" ++
                 "    }\n" ++
                 "}\n";
    let runner = generate_runner_chain(test_names, 0);
    let nat_helper = "\nfn _harness_nat_to_string(n: Nat) -> String {\n" ++
                     "    if n == 0 { \"0\" }\n" ++
                     "    else if n == 1 { \"1\" }\n" ++
                     "    else if n == 2 { \"2\" }\n" ++
                     "    else if n == 3 { \"3\" }\n" ++
                     "    else if n == 4 { \"4\" }\n" ++
                     "    else if n == 5 { \"5\" }\n" ++
                     "    else if n == 6 { \"6\" }\n" ++
                     "    else if n == 7 { \"7\" }\n" ++
                     "    else if n == 8 { \"8\" }\n" ++
                     "    else if n == 9 { \"9\" }\n" ++
                     "    else { \"many\" }\n" ++
                     "}\n";
    header ++ "\n" ++ runner ++ nat_helper
}

/// Generate a chain of test runner functions.
fn generate_runner_chain(names: List<String>, index: Nat) -> String {
    match names {
        Nil() => generate_terminal_runner(index),
        Cons(name, rest) =>
            let this_fn = generate_test_runner_fn(name, index);
            let rest_fns = generate_runner_chain(rest, index + 1);
            this_fn ++ "\n" ++ rest_fns
    }
}

/// Generate the terminal runner (base case).
fn generate_terminal_runner(index: Nat) -> String {
    "fn _harness_run_tests(failed: Nat) -> Nat {\n" ++
    "    _harness_run_test_" ++ nat_to_string(index) ++ "(failed)\n" ++
    "}\n\n" ++
    "fn _harness_run_test_" ++ nat_to_string(index) ++ "(failed: Nat) -> Nat {\n" ++
    "    failed\n" ++
    "}\n"
}

/// Generate a runner function for a single test.
fn generate_test_runner_fn(name: String, index: Nat) -> String {
    let next_index = nat_to_string(index + 1);
    let this_index = nat_to_string(index);
    "fn _harness_run_test_" ++ this_index ++ "(failed: Nat) -> Nat {\n" ++
    "    _harness_test_begin(\"" ++ name ++ "\");\n" ++
    "    " ++ name ++ "();\n" ++
    "    if tg_test_check_failure() == 1 {\n" ++
    "        _harness_println(\"  " ++ name ++ " ... FAILED\");\n" ++
    "        _harness_run_test_" ++ next_index ++ "(failed + 1)\n" ++
    "    } else {\n" ++
    "        _harness_println(\"  " ++ name ++ " ... ok\");\n" ++
    "        _harness_run_test_" ++ next_index ++ "(failed)\n" ++
    "    }\n" ++
    "}\n"
}
