// src/compiler/driver/modules/parse.tg
// Module tree parsing with cycle detection.

use driver::ffi::{List, Nil, Cons, read_file, parent_directory, FfiResult, FfiOk, FfiErr};
use driver::util::{Option, Some, None, unwrap_or};
use driver::util::{
    Result, Ok, Err, result_map,
    string_is_empty, string_concat, list_contains_string, list_reverse
};
use parser::ast::common::{Visibility, VisPublic};
use parser::ast::nodes::{
    Item, ItemMod, ModDecl,
    source_file_items
};
use parser::lib::{parse_to_source_file};

use driver::modules::tree::parsed::{ParsedModule, ParsedModuleErrors, parsed_module_new};
use driver::modules::resolve::{resolve_module_path};

/// Directory context for submodule resolution.
type SubmoduleDirCtx = {
    parent_dir: String,
    referenced_from: String
}

// ===========================================================================
// MODULE TREE PARSING
// ===========================================================================

/// Parse a module tree starting from the given path.
///
/// Returns Ok((parsed_module, visited_paths)) on success,
/// or Err(error_message) on failure.
pub fn parse_module_tree(
    path: String,
    visited: List<String>
) -> Result<(ParsedModule, List<String>), String> {
    let result = parse_module_tree_with_visibility(path, VisPublic, visited);
    result
}

/// Parse module tree with explicit visibility.
fn parse_module_tree_with_visibility(
    path: String,
    visibility: Visibility,
    visited: List<String>
) -> Result<(ParsedModule, List<String>), String> {
    // Cycle detection
    if list_contains_string(visited, path) {
        Err(string_concat("Module cycle detected: ", path))
    } else {
        // Add to visited
        let new_visited = Cons(path, visited);
        
        // Read and parse source
        match read_file(path) {
            FfiErr(e) => Err(string_concat("Could not read file: ", path)),
            FfiOk(source) => {
                let result = parse_module_source(source, path, visibility, new_visited);
                result
            }
        }
    }
}

/// Parse module from source content.
fn parse_module_source(
    source: String,
    path: String,
    visibility: Visibility,
    new_visited: List<String>
) -> Result<(ParsedModule, List<String>), String> {
    if string_is_empty(source) {
        Err(string_concat("Empty file: ", path))
    } else {
        // Parse the source file
        let (source_file, parse_errors, lex_errors) = parse_to_source_file(source, path);
        
        // Resolve submodules
        let parent_dir = unwrap_or(parent_directory(path), ".");
        let items = source_file_items(source_file);
        
        let submodules_result = {
            let dir_ctx: SubmoduleDirCtx = { parent_dir: parent_dir, referenced_from: path };
            resolve_submodules(items, dir_ctx, new_visited, Nil)
        };
        match submodules_result {
            Ok(pair) => {
                let (submodules, final_visited) = pair;
                let errors: ParsedModuleErrors = { parse_errors: parse_errors, lex_errors: lex_errors };
                let module = parsed_module_new(
                    path,
                    visibility,
                    source_file,
                    errors,
                    submodules
                );
                Ok((module, final_visited))
            },
            Err(e) => {
                Err(e)
            }
        }
    }
}

/// Resolve all submodules from a list of items.
fn resolve_submodules(
    items: List<Item>,
    dir_ctx: SubmoduleDirCtx,
    visited: List<String>,
    acc: List<ParsedModule>
) -> Result<(List<ParsedModule>, List<String>), String> {
    match items {
        Nil() => Ok((list_reverse(acc), visited)),
        Cons(item, rest) =>
            resolve_submodule_step(item, rest, dir_ctx, visited, acc)
    }
}

fn resolve_submodule_step(
    item: Item,
    rest: List<Item>,
    dir_ctx: SubmoduleDirCtx,
    visited: List<String>,
    acc: List<ParsedModule>
) -> Result<(List<ParsedModule>, List<String>), String> {
    match item {
        ItemMod(mod_decl) =>
            resolve_one_submodule(
                mod_decl, dir_ctx,
                visited, acc, rest
            ),
        _ =>
            resolve_submodules(rest, dir_ctx, visited, acc)
    }
}

fn resolve_one_submodule(
    mod_decl: ModDecl,
    dir_ctx: SubmoduleDirCtx,
    visited: List<String>,
    acc: List<ParsedModule>,
    rest_items: List<Item>
) -> Result<(List<ParsedModule>, List<String>), String> {
    let name = mod_decl.name.name;
    let vis = mod_decl.vis;
    
    match resolve_module_path(dir_ctx.parent_dir, name, dir_ctx.referenced_from) {
        Err(e) => Err(e),
        Ok(sub_path) =>
            match parse_module_tree_with_visibility(sub_path, vis, visited) {
                Err(e) => Err(e),
                Ok(result) => {
                    let (sub_module, new_visited) = result;
                    resolve_submodules(
                        rest_items, dir_ctx,
                        new_visited, Cons(sub_module, acc)
                    )
                }
            }
    }
}
