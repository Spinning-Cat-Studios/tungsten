}

// ===========================================================================
// BOOLEAN OPERATIONS: Bool -> Bool -> Bool
// ===========================================================================

fn synth_bool_and(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let bool_ty = tg_type_bool();
    match check(env, left, bool_ty) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("&&", span))),
        ElabExprOk(env2, left_term, _, left_cir) =>
            match check(env2, right, bool_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("&&", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    let result_term = tg_term_bool_and(left_term, right_term);
                    let result_cir = CIRBoolAnd(left_cir, right_cir);
                    ElabExprOk(env3, result_term, bool_ty, result_cir)
            }
    }
}

fn synth_bool_or(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let bool_ty = tg_type_bool();
    match check(env, left, bool_ty) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("||", span))),
        ElabExprOk(env2, left_term, _, left_cir) =>
            match check(env2, right, bool_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("||", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    let result_term = tg_term_bool_or(left_term, right_term);
                    let result_cir = CIRBoolOr(left_cir, right_cir);
                    ElabExprOk(env3, result_term, bool_ty, result_cir)
            }
    }
}

// ===========================================================================
// STRING AND OTHER OPERATIONS
// ===========================================================================

/// Synthesize string concatenation.
fn synth_str_concat(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let string_ty = tg_type_string();
    match check(env, left, string_ty) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("++", span))),
        ElabExprOk(env2, left_term, _, left_cir) =>
            match check(env2, right, string_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("++", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    let result_term = tg_term_str_concat(left_term, right_term);
                    let result_cir = CIRStrConcat(left_cir, right_cir);
                    ElabExprOk(env3, result_term, string_ty, result_cir)
            }
    }
}

/// Synthesize pipe operator: a |> f  =  f(a)
fn synth_pipe(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    // Desugar to application: f(a)
    let app_expr = ExprApp(right, Cons(left, Nil), span);
    synth(env, app_expr)
}

// ===========================================================================
// UNARY OPERATORS
// ===========================================================================

/// Synthesize a unary operation.
pub fn synth_unary(env: Env, op: UnaryOp, operand: Expr, span: Span) -> ElabExprResult {
    match op {
        OpNot() =>
            // ! : Bool -> Bool
            let bool_ty = tg_type_bool();
            match check(env, operand, bool_ty) {
                ElabExprErr(e) => ElabExprErr(e),
                ElabExprOk(env2, term, _, operand_cir) =>
                    let result = tg_term_bool_not(term);
                    let result_cir = CIRBoolNot(operand_cir);
                    ElabExprOk(env2, result, bool_ty, result_cir)
            },
        OpNeg() =>
            // - : Nat -> Nat (for now; should be for signed integers)
            // TODO: Nat subtraction from 0 would require special handling
            ElabExprErr(elab_expr_error(
                "unary negation not yet implemented for Nat",
                span
            ))
    }
}
