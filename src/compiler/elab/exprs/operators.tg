// ===========================================================================
// POLYMORPHIC EQUALITY: infer left type, check right, dispatch
// ===========================================================================

/// Polymorphic equality: infer type from left operand, check right matches.
fn synth_polymorphic_eq(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let bool_ty = tg_type_bool();
    let nat_ty = tg_type_nat();
    let string_ty = tg_type_string();
    
    // Infer the type of the left operand
    match synth(env, left) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("==", span))),
        ElabExprOk(env2, left_term, left_ty, left_cir) =>
            // Check right operand against left's type
            match check(env2, right, left_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("==", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    // Dispatch based on type
                    if tg_types_equal(left_ty, nat_ty) {
                        let result_term = tg_term_nat_eq(left_term, right_term);
                        let result_cir = CIRNatEq(left_cir, right_cir);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else if tg_types_equal(left_ty, string_ty) {
                        let result_term = tg_term_str_eq(left_term, right_term);
                        let result_cir = CIRStrEq(left_cir, right_cir);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else if tg_types_equal(left_ty, bool_ty) {
                        // Bool equality: a == b iff (a && b) || (!a && !b)
                        // Simplified: use XOR then negate, or just compare directly
                        // For now, use the pattern: (a && b) || ((!a) && (!b))
                        let a_and_b = tg_term_bool_and(left_term, right_term);
                        let not_a = tg_term_bool_not(left_term);
                        let not_b = tg_term_bool_not(right_term);
                        let not_a_and_not_b = tg_term_bool_and(not_a, not_b);
                        let result_term = tg_term_bool_or(a_and_b, not_a_and_not_b);
                        // CIR doesn't have a direct bool_eq, so build the same pattern
                        let cir_a_and_b = CIRBoolAnd(left_cir, right_cir);
                        let cir_not_a = CIRBoolNot(left_cir);
                        let cir_not_b = CIRBoolNot(right_cir);
                        let cir_not_a_and_not_b = CIRBoolAnd(cir_not_a, cir_not_b);
                        let result_cir = CIRBoolOr(cir_a_and_b, cir_not_a_and_not_b);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else {
                        ElabExprErr(elab_expr_error(
                            "equality not supported for this type",
                            span
                        ))
                    }
            }
    }
}

/// Polymorphic inequality: uses polymorphic_eq then negates.
fn synth_polymorphic_ne(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let bool_ty = tg_type_bool();
    let nat_ty = tg_type_nat();
    let string_ty = tg_type_string();
    
    // Infer the type of the left operand
    match synth(env, left) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("!=", span))),
        ElabExprOk(env2, left_term, left_ty, left_cir) =>
            // Check right operand against left's type
            match check(env2, right, left_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("!=", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    // Dispatch based on type, then negate
                    if tg_types_equal(left_ty, nat_ty) {
                        let eq_term = tg_term_nat_eq(left_term, right_term);
                        let result_term = tg_term_bool_not(eq_term);
                        let eq_cir = CIRNatEq(left_cir, right_cir);
                        let result_cir = CIRBoolNot(eq_cir);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else if tg_types_equal(left_ty, string_ty) {
                        let eq_term = tg_term_str_eq(left_term, right_term);
                        let result_term = tg_term_bool_not(eq_term);
                        let eq_cir = CIRStrEq(left_cir, right_cir);
                        let result_cir = CIRBoolNot(eq_cir);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else if tg_types_equal(left_ty, bool_ty) {
                        // Bool inequality: a != b iff XOR
                        // (a || b) && (!a || !b)  equivalent to  (a && !b) || (!a && b)
                        let not_a = tg_term_bool_not(left_term);
                        let not_b = tg_term_bool_not(right_term);
                        let a_and_not_b = tg_term_bool_and(left_term, not_b);
                        let not_a_and_b = tg_term_bool_and(not_a, right_term);
                        let result_term = tg_term_bool_or(a_and_not_b, not_a_and_b);
                        // CIR version
                        let cir_not_a = CIRBoolNot(left_cir);
                        let cir_not_b = CIRBoolNot(right_cir);
                        let cir_a_and_not_b = CIRBoolAnd(left_cir, cir_not_b);
                        let cir_not_a_and_b = CIRBoolAnd(cir_not_a, right_cir);
                        let result_cir = CIRBoolOr(cir_a_and_not_b, cir_not_a_and_b);
                        ElabExprOk(env3, result_term, bool_ty, result_cir)
                    } else {
                        ElabExprErr(elab_expr_error(
                            "inequality not supported for this type",
                            span
                        ))
                    }
            }
    }
}

// ===========================================================================
// COMPARISON OPERATIONS: Nat -> Nat -> Bool
// ===========================================================================

fn synth_nat_eq(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    let nat_ty = tg_type_nat();
    let bool_ty = tg_type_bool();
    match check(env, left, nat_ty) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("==", span))),
        ElabExprOk(env2, left_term, _, left_cir) =>
            match check(env2, right, nat_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("==", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    let result_term = tg_term_nat_eq(left_term, right_term);
                    let result_cir = CIRNatEq(left_cir, right_cir);
                    ElabExprOk(env3, result_term, bool_ty, result_cir)
            }
    }
}

fn synth_nat_ne(env: Env, left: Expr, right: Expr, span: Span) -> ElabExprResult {
    // a != b  =  !(a == b)
    let nat_ty = tg_type_nat();
    let bool_ty = tg_type_bool();
    match check(env, left, nat_ty) {
        ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("!=", span))),
        ElabExprOk(env2, left_term, _, left_cir) =>
            match check(env2, right, nat_ty) {
                ElabExprErr(e) => ElabExprErr(add_expected_because(e, ExpBinaryOperand("!=", span))),
                ElabExprOk(env3, right_term, _, right_cir) =>
                    let eq_term = tg_term_nat_eq(left_term, right_term);
                    let ne_term = tg_term_bool_not(eq_term);
                    let eq_cir = CIRNatEq(left_cir, right_cir);
                    let ne_cir = CIRBoolNot(eq_cir);
                    ElabExprOk(env3, ne_term, bool_ty, ne_cir)
            }
    }
}

