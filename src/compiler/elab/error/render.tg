    // These are best detected at parse time, so this is a placeholder
    // for elaboration-time detection of semantic patterns
    Nil
}

/// Create a suggestion for using braces instead of 'then'.
pub fn suggest_brace_syntax(span: Span) -> Suggestion {
    { span: span, replacement: "{ ... }", message: "Tungsten uses braces for if-then-else: if cond { then } else { else }" }
}

/// Create a suggestion for using // instead of --.
pub fn suggest_line_comment(span: Span) -> Suggestion {
    { span: span, replacement: "//", message: "Tungsten uses // for line comments" }
}
